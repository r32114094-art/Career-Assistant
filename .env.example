# Copy this file to .env and fill in your own keys
# cp .env.example .env

# ── DeepSeek API ──────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1   # default, usually no need to change

DEEPSEEK_MODEL=deepseek-chat         # fast model for routing/classification
DEEPSEEK_MODEL_PRO=deepseek-reasoner # powerful model for generation tasks

# ── SerpAPI (job search) ──────────────────────────────────────────────────
SERPAPI_API_KEY=your_serpapi_key_here

# ── LangSmith (optional tracing) ─────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=GenAI Career Assistant

# ── Memory storage ────────────────────────────────────────────────────────
# Default (local SQLite): omit DATABASE_URL — saved to data/memory.db
# Cloud (PostgreSQL):     uncomment and fill in below
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth (access codes, comma-separated) ─────────────────────────────────
# Local: reads from data/credentials.json (default)
# Cloud: set this env var, takes priority over JSON file
# ACCESS_CODES=bole2026,career888,demo1234
